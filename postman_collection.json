              "path": ["events", "2"]
            }
          }
        },
        {
          "name": "Supprimer un événement",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/events/12",
              "host": ["{{base_url}}"],
              "path": ["events", "12"]
            }
          }
        },
        {
          "name": "Supprimer — sans token (401)",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/events/12",
              "host": ["{{base_url}}"],
              "path": ["events", "12"]
            }
          }
        }
      ]
    },
    {
