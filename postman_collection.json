            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Conférence Tech Ouaga 2026\",\n  \"date\": \"2026-05-15T09:00:00Z\",\n  \"location\": \"Ouagadougou\",\n  \"capacity\": 100\n}",
              "options": {
                "raw": {
