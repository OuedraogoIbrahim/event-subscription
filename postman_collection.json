{
  "info": {
    "name": "Event Management API",
    "description": "Collection complète pour tester l'API de gestion d'événements",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000/api",
      "type": "string"
    },
    {
      "key": "admin_token",
      "value": "sk-evt-admin-2025-dev-12345abcdef67890",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Événements",
      "item": [
        {
          "name": "Lister les événements",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/events",
              "host": ["{{base_url}}"],
              "path": ["events"]
            }
          }
        },
        {
          "name": "Lister avec recherche",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/events?search=Laravel",
              "host": ["{{base_url}}"],
              "path": ["events"],
              "query": [
                {
                  "key": "search",
                  "value": "Laravel"
                }
              ]
            }
          }
        },
        {
          "name": "Lister avec filtre date",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/events?date=2025-11",
              "host": ["{{base_url}}"],
              "path": ["events"],
              "query": [
                {
                  "key": "date",
                  "value": "2025-11"
                }
              ]
            }
          }
        },
        {
          "name": "Lister avec pagination",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/events?limit=5&page=1",
              "host": ["{{base_url}}"],
              "path": ["events"],
              "query": [
                {
                  "key": "limit",
                  "value": "5"
                },
                {
                  "key": "page",
                  "value": "1"
                }
              ]
            }
          }
        },
        {
          "name": "Détail d'un événement",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/events/1",
              "host": ["{{base_url}}"],
              "path": ["events", "1"]
            }
          }
        },
        {
          "name": "Détail — événement inexistant (404)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/events/99999",
              "host": ["{{base_url}}"],
              "path": ["events", "99999"]
            }
          }
        },
        {
          "name": "Créer un événement",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Conférence Tech Ouaga 2026\",\n  \"description\": \"Les dernières tendances en développement web et mobile.\",\n  \"date\": \"2026-05-15T09:00:00Z\",\n  \"location\": \"Ouagadougou, Salle des fêtes de Ouaga 2000\",\n  \"capacity\": 100\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/events",
              "host": ["{{base_url}}"],
              "path": ["events"]
            }
          }
        },
        {
          "name": "Créer un événement — sans token (401)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
